# Copy to .env and fill in. Startup fails fast if a required key is missing.

# ── Required credentials ──────────────────────────────────────────────

# Sarvam (TTS) — https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Deepgram (STT) — https://console.deepgram.com
DEEPGRAM_API_KEY=

# Vobiz (telephony)
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=

# Shared secret protecting the /ws audio socket. /answer embeds it in the
# wss:// URL handed to Vobiz; /ws rejects connects without it. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
WS_AUTH_TOKEN=

# ── Reachability ──────────────────────────────────────────────────────

# Public hostname Vobiz can reach (no scheme). Local dev: your ngrok host.
PUBLIC_HOST=localhost:8000

# Your Vobiz DID, used as the default caller ID by make_call.py
FROM_NUMBER=

VOBIZ_API_BASE=https://api.vobiz.ai/api/v1

# ── LLM (any OpenAI-compatible endpoint) ──────────────────────────────

LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2:7b
LLM_TEMPERATURE=0.6

# ── TTS ───────────────────────────────────────────────────────────────

TTS_MODEL=bulbul:v3
TTS_SPEAKER=shubh
TTS_LANGUAGE=hi-IN
TTS_PACE=1.05

# ── Turn-taking / latency ─────────────────────────────────────────────

ENDPOINT_SILENCE_MS=550
BARGEIN_RMS_THRESHOLD=650
BARGEIN_MIN_FRAMES=25
VAD_AGGRESSIVENESS=2

# Tiny "हम्म" that masks LLM time-to-first-token; set empty to disable
THINKING_FILLER=हम्म

# ── Observability ─────────────────────────────────────────────────────

# "text" (dev default) or "json" (one JSON object per log line, for prod
# log pipelines). Conversation events are always structured either way.
LOG_FORMAT=text
# Per-call transcript records (JSONL), written by a bus subscriber
TRANSCRIPTS_PATH=transcripts.jsonl

# Priya's persona (system prompt, greeting, knowledge, voice) now lives in
# agents/priya.json, not here. config.py holds only credentials + the engine
# defaults an agent inherits for any policy its file doesn't pin.
